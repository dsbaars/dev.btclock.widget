<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon for the launcher. Background + foreground are the two
  required layers; monochrome supplies a single-tone version for
  Android 13+ themed-icon mode (the launcher tints it to match the
  user's wallpaper-derived theme).
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
