<?xml version="1.0" encoding="utf-8"?>
<!--
  Stand-in shown to the launcher (widget picker preview + the
  brief moment between widget add and the first Glance render).
  Glance overrides this RemoteViews with its own once provideGlance
  runs.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="BTClock"
        android:textColor="#F1C64A"
        android:textSize="24sp"
        android:textStyle="italic" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif"
        android:text="@string/widget_loading"
        android:textColor="#808080"
        android:textSize="11sp" />
</LinearLayout>
