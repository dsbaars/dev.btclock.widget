<?xml version="1.0" encoding="utf-8"?>
<!--
  Solid dark PCB-soldermask background. The adaptive-icon layer covers
  the full 108dp viewport; the launcher applies its own mask (circle,
  squircle, rounded square) on top so we don't draw rounded corners
  ourselves — that would clash with masks shaped any other way.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0A0A0A" />
</shape>
